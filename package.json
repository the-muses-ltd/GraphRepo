{
  "name": "graphrepo",
  "version": "0.1.0",
  "description": "Neo4j + GraphRAG powered tool for visualizing and querying code repositories",
  "type": "module",
  "scripts": {
    "parse": "tsx src/cli/index.ts parse",
    "serve": "tsx src/cli/index.ts serve",
    "viz": "tsx src/cli/index.ts viz",
    "build:web": "esbuild src/web/main.ts --bundle --outfile=dist/web/bundle.js --format=esm --platform=browser && cp src/web/index.html src/web/styles.css dist/web/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.0.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "neo4j-driver": "^5.27.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.0",
    "@types/d3-selection": "^3.0.0",
    "@types/d3-zoom": "^3.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
