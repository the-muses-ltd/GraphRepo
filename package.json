{
  "name": "graphrepo",
  "displayName": "GraphRepo",
  "version": "0.2.0",
  "description": "GraphRAG-powered tool for visualizing and querying code repositories",
  "publisher": "the-muses-ltd",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-muses-ltd/GraphRepo.git"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "graphrepo",
          "title": "GraphRepo",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "graphrepo": [
        {
          "type": "webview",
          "id": "graphrepo.graphView",
          "name": "Code Graph"
        }
      ]
    },
    "commands": [
      {
        "command": "graphrepo.parseWorkspace",
        "title": "GraphRepo: Parse Workspace",
        "icon": "$(play)"
      },
      {
        "command": "graphrepo.searchCodeGraph",
        "title": "GraphRepo: Search Code Graph",
        "icon": "$(search)"
      },
      {
        "command": "graphrepo.refreshGraph",
        "title": "GraphRepo: Refresh Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "graphrepo.configureMcp",
        "title": "GraphRepo: Configure MCP for Claude"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "graphrepo.parseWorkspace",
          "when": "view == graphrepo.graphView",
          "group": "navigation@1"
        },
        {
          "command": "graphrepo.searchCodeGraph",
          "when": "view == graphrepo.graphView",
          "group": "navigation@2"
        },
        {
          "command": "graphrepo.refreshGraph",
          "when": "view == graphrepo.graphView",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "GraphRepo",
      "properties": {}
    }
  },
  "scripts": {
    "parse": "tsx src/cli/index.ts parse",
    "communities": "tsx src/cli/index.ts communities",
    "serve": "tsx src/cli/index.ts serve",
    "viz": "tsx src/cli/index.ts viz",
    "build:web": "esbuild src/web/main.ts --bundle --outfile=dist/web/bundle.js --format=esm --platform=browser && cp src/web/index.html src/web/styles.css dist/web/",
    "build:ext": "node esbuild.extension.mjs",
    "build:webview": "node esbuild.webview.mjs",
    "build:mcp": "node esbuild.mcp-server.mjs",
    "build:vscode": "npm run build:ext && npm run build:webview",
    "watch:ext": "node esbuild.extension.mjs --watch",
    "watch:webview": "node esbuild.webview.mjs --watch",
    "vscode:prepublish": "npm run build:vscode && npm run build:mcp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.0.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.0",
    "@types/d3-selection": "^3.0.0",
    "@types/d3-zoom": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
